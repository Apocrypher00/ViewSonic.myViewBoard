<?xml version="1.0" encoding="utf-8"?>
<Types>
    <Type>
        <Name>ViewSonic.myViewBoard.DeviceStatistics</Name>
        <Members>
            <ScriptProperty>
                <Name>TotalUptime</Name>
                <GetScriptBlock>
                    $Hours, $null, $Minutes, $null = $this.total_uptime.Split(" ")
                    $([TimeSpan]::new($Hours, $Minutes, 0))
                </GetScriptBlock>
            </ScriptProperty>
        </Members>
    </Type>
</Types>
