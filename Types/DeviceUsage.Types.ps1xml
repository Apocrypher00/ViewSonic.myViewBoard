<?xml version="1.0" encoding="utf-8"?>
<Types>
    <Type>
        <Name>ViewSonic.myViewBoard.DeviceUsage</Name>
        <Members>
            <ScriptProperty>
                <Name>UsageTime</Name>
                <GetScriptBlock>
                    $Hours, $Minutes = $this.usage_time.Split(".")
                    $([TimeSpan]::new($Hours, $Minutes, 0))
                </GetScriptBlock>
            </ScriptProperty>
        </Members>
    </Type>
</Types>
